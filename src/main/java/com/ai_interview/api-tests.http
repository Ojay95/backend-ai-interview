### Variables
@host = https://backend-ai-interview-jx2h.onrender.com

### 1. Register a New User
# This will automatically save the token to {{auth_token}}
POST {{host}}/api/v1/auth/register
Content-Type: application/json

{
  "firstName": "AbdulAhmid",
  "lastName": "Akinsola",
  "email": "iamojay89@gmail.com",
  "password": "guns.lots.of.guns"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200 || response.status === 201, "Response status is not 200/201");
    });
    // Matches your AuthResponse.java field 'access_token'
    client.global.set("auth_token", response.body.access_token);
%}

###

### 2. Login (Get Token)
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "iamojay89@gmail.com",
  "password": "guns.lots.of.guns"
}

> {%
    client.test("Login successful", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    // Saves the token for all subsequent requests
    client.global.set("auth_token", response.body.access_token);
%}

###

### 3. Get My Profile (Protected)
GET {{host}}/api/v1/users/me
Authorization: Bearer {{auth_token}}
Accept: application/json

### 4. Get All Jobs (Public)
GET {{host}}/api/v1/jobs
Accept: application/json

### 5. Seed Jobs (Populate database)
POST {{host}}/api/v1/jobs/seed?industry=Technology
Authorization: Bearer {{auth_token}}

### 6. Start Interview Session
POST {{host}}/api/v1/interviews/start
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "jobId": 1,
  "cvId": 1
}

### 7. Chat with Sarah (AI Interviewer)
POST {{host}}/api/v1/interviews/chat
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "sessionId": 1,
  "userMessage": "I am a backend developer with experience in Java and Spring Boot."
}

### 8. Get Interview History
GET {{host}}/api/v1/interviews/history
Authorization: Bearer {{auth_token}}

### 9. Get Dashboard Stats
GET {{host}}/api/v1/analytics/stats
Authorization: Bearer {{auth_token}}

### 10. Get My Preferences
GET {{host}}/api/v1/user/preferences
Authorization: Bearer {{auth_token}}

### 11. Update Preferences
PUT {{host}}/api/v1/user/preferences
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "voiceModel": "Echo",
  "speechSpeed": 1.2,
  "interviewerPersona": "executive"
}

### 12. Submit Support Ticket (Public)
POST {{host}}/api/v1/public/support/contact
Content-Type: application/json

{
  "firstName": "Abdul",
  "lastName": "Akinsola",
  "email": "jayclassics2000@gmail.com",
  "message": "I need help with my live deployment."
}